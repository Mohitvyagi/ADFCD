										"type": "integer"
									},
									"DNAME": {
										"type": "string"
									},
									"LOC": {
										"type": "string"
									},
									"STAFF": {
										"type": "array",
										"items": {
											"type": "object",
											"properties": {
												"EMPNO": {
													"type": "integer"
												},
												"ENAME": {
													"type": "string"
												},
												"JOB": {
													"type": "string"
												},
												"MGR": {
													"type": "null"
												},
												"HIREDATE": {
													"type": "string"
												},
												"SAL": {
													"type": "integer"
												},
												"COMM": {
													"type": "null"
												}
											}
										}
									}
								}
							}
						}
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_inpiut_blob')]"
