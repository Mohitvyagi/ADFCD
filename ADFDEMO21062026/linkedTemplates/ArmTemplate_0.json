					"location": {
						"type": "AzureBlobFSLocation",
						"folderPath": "input",
						"fileSystem": "bronzecontainer"
					},
					"columnDelimiter": ",",
					"escapeChar": "\\",
					"firstRowAsHeader": true,
					"quoteChar": "\""
				},
				"schema": [
					{
						"name": "emp_id",
						"type": "String"
